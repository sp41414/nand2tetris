/**
 * Exclusive-or gate:
 * if ((a and Not(b)) or (Not(a) and b)) out = 1, else out = 0
 */
CHIP Xor {
    IN a, b;
    OUT out;

    PARTS:
    /* pretty self-explanatory now that we have the Not, And and Or parts. */
    Not(in=a, out=nota);
    Not(in=b, out=notb);
    And(a=a, b=notb, out=andNotB);
    And(a=nota, b=b, out=andNotA);
    Or(a=andNotB, b=andNotA, out=out);
}
